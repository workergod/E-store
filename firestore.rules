rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Function to fetch the user's role from the users collection
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Function to get the user's company ID
    function getUserCompanyId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId;
    }

    function isSuperAdmin() {
      return getUserRole() == 'SuperAdmin';
    }

    function isOwner() {
      return getUserRole() == 'Owner';
    }

    // -----------------------------------------------------
    // USERS COLLECTION
    // -----------------------------------------------------
    match /users/{userId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (isOwner() && resource.data.companyId == getUserCompanyId())
      );
      
      allow create: if isAuthenticated() && (
        isSuperAdmin() || 
        (isOwner() && request.resource.data.companyId == getUserCompanyId()) ||
        request.auth.uid == userId // Allow auto-registration
      );

      allow update: if isAuthenticated() && (
        request.auth.uid == userId || 
        isSuperAdmin() ||
        (isOwner() && resource.data.companyId == getUserCompanyId())
      );
    }

    // -----------------------------------------------------
    // COMPANIES COLLECTION
    // -----------------------------------------------------
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (
        isSuperAdmin() || resource.id == getUserCompanyId()
      );
      
      allow write: if isAuthenticated() && isSuperAdmin();
    }

    // -----------------------------------------------------
    // LOGIN HISTORY & AUDIT LOGS
    // -----------------------------------------------------
    match /loginHistory/{docId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && isSuperAdmin();
    }

    match /auditLogs/{docId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (
        isSuperAdmin() || (isOwner() && resource.data.companyId == getUserCompanyId())
      );
    }

    // -----------------------------------------------------
    // MASTER DATA & INVENTORY
    // -----------------------------------------------------
    match /categories/{document} { allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId); allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId); }
    match /brands/{document} { allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId); allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId); }
    match /units/{document} { allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId); allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId); }
    match /productTypes/{document} { allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId); allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId); }
    match /manufacturers/{document} { allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId); allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId); }
    match /rackLocations/{document} { allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId); allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId); }
    match /productTemplates/{document} { allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId); allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId); }

    match /products/{document} {
      allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
    }
    match /stockLedger/{document} {
      allow read: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
      allow update, delete: if isSuperAdmin();
    }

    // --- Purchase & Supplier (Phase 5) ---
    match /suppliers/{document} {
      allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
    }
    match /purchaseOrders/{document} {
      allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
    }
    match /productPriceHistory/{document} {
      allow read: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
      allow update, delete: if isSuperAdmin(); // History should generally be immutable
    }

    // --- Stock Management (Phase 6) ---
    match /stockSnapshots/{document} {
      allow read: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
      allow update, delete: if isSuperAdmin(); // Immutable
    }
    match /stockAdjustments/{document} {
      allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
    }

    // --- Phase 7 (Employees & Documents) ---
    match /documents/{document} {
      allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
    }
    match /employees/{document} {
      allow read: if isSuperAdmin() || isCompanyMember(resource.data.companyId) || (isAuthenticated() && resource.data.email == request.auth.token.email);
      allow write: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
    }
    match /employeeSkills/{document} {
      allow read, write: if isSuperAdmin() || isCompanyMember(resource.data.companyId);
      allow create: if isSuperAdmin() || isCompanyMember(request.resource.data.companyId);
    }
  }
}
